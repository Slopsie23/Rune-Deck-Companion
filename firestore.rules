rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidDeck(data) {
      return data.id is string && data.id.size() <= 100
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 200
        && data.tags is list && data.tags.size() <= 50
        && data.commanders is list && data.commanders.size() <= 5
        && data.art_crops is list && data.art_crops.size() <= 5
        && data.ci is string && data.ci.size() <= 10
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidCard(data) {
      return data.name is string && data.name.size() <= 200
        && data.userId == request.auth.uid
        && data.thumb is string
        && data.from_deck is string
        && data.qty is int && data.qty >= 0 && data.qty <= 999;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().userId == userId
        && incoming().email is string
        && incoming().keys().size() <= 8;
      allow update: if isOwner(userId)
        && incoming().userId == userId;

      // --- Decks ---
      match /decks/{deckId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) 
          && isValidDeck(incoming())
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;
        allow update: if isOwner(userId)
          && isValidDeck(incoming())
          && incoming().createdAt == existing().createdAt
          && incoming().updatedAt == request.time
          && (
            incoming().diff(existing()).affectedKeys().hasOnly(['name', 'tags', 'commanders', 'art_crops', 'ci', 'updatedAt'])
          );
        allow delete: if isOwner(userId);
      }

      // --- Deckbox (Selection) ---
      match /deckbox/{cardId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCard(incoming());
        allow update: if isOwner(userId) && isValidCard(incoming())
          && incoming().diff(existing()).affectedKeys().hasOnly(['qty']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
