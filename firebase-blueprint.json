{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User metadata and settings",
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "photoURL": { "type": "string" },
        "userTitle": { "type": "string" },
        "cardsPerRowDesktop": { "type": "number" },
        "cardsPerRowMobile": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Deck": {
      "title": "Saved Deck",
      "description": "A collection of cards with metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "commanders": { "type": "array", "items": { "type": "string" } },
        "ci": { "type": "string" },
        "totalCost": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in Ruxa chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role", "content", "timestamp"]
    },
    "DeckAnalysis": {
      "title": "Deck Synergy Analysis",
      "description": "AI analysis of deck synergies",
      "type": "object",
      "properties": {
        "deckId": { "type": "string" },
        "analysisText": { "type": "string" },
        "synergyRunes": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["deckId", "analysisText", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "The user document itself"
    },
    "/users/{userId}/decks/{deckId}": {
      "schema": "Deck",
      "description": "User saved decks"
    },
    "/users/{userId}/ruxa_chat/{messageId}": {
      "schema": "ChatMessage",
      "description": "Ruxa chat history"
    },
    "/users/{userId}/decks/{deckId}/analysis/{analysisId}": {
      "schema": "DeckAnalysis",
      "description": "Advanced synergy analysis for a specific deck"
    }
  }
}
